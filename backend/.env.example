APP_NAME=Barcode Management System
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

# ──────────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=barcode_management
DB_USERNAME=barcode_user
DB_PASSWORD=barcode_password

# ──────────────────────────────────────────────
# Cache
# ──────────────────────────────────────────────
CACHE_DRIVER=file
# CACHE_DRIVER=redis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# ──────────────────────────────────────────────
# Queue
# ──────────────────────────────────────────────
QUEUE_CONNECTION=sync
# QUEUE_CONNECTION=database
# QUEUE_TABLE=jobs

# ──────────────────────────────────────────────
# Session
# ──────────────────────────────────────────────
SESSION_DRIVER=file
# SESSION_DRIVER=redis
# SESSION_LIFETIME=120

# ──────────────────────────────────────────────
# Mail
# ──────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@barcode-management.local"
MAIL_FROM_NAME="${APP_NAME}"

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ──────────────────────────────────────────────
# Sanctum (API Authentication)
# ──────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,localhost:5173
SESSION_DRIVER=cookie
